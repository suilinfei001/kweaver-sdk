# KWeaver E2E test environment
# Copy to .env.e2e and fill in real values:
#   cp .env.e2e.example .env.e2e

# KWeaver platform
KWEAVER_BASE_URL=https://your-kweaver-instance.example.com
KWEAVER_USERNAME=your-username
KWEAVER_PASSWORD=your-password
KWEAVER_BUSINESS_DOMAIN=bd_public

# Test database (for --build mode and datasource tests)
KWEAVER_TEST_DB_TYPE=mysql
KWEAVER_TEST_DB_HOST=your-db-host
KWEAVER_TEST_DB_PORT=3306
KWEAVER_TEST_DB_NAME=your-db-name
KWEAVER_TEST_DB_USER=your-db-user
KWEAVER_TEST_DB_PASS=your-db-password
